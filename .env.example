# ============================================================
# VoxNPC — Configuração de Ambiente
# ============================================================
# Copie este arquivo para .env e preencha com suas credenciais.
# NUNCA faça commit do arquivo .env no repositório.
# ============================================================

# Chave da API da OpenAI (obrigatória)
OPENAI_API_KEY=sk-sua-chave-aqui

# Modelo do ChatGPT (opcional — padrão: gpt-3.5-turbo)
OPENAI_MODEL=gpt-3.5-turbo

# Modelo do Whisper (opcional — padrão: base)
# Opções: tiny, base, small, medium, large
WHISPER_MODEL=base

# Idioma padrão para Text-to-Speech (opcional — padrão: pt-br)
TTS_LANGUAGE=pt-br

# Persona padrão do NPC (opcional — padrão: sage)
DEFAULT_PERSONA=sage

# Modo de depuração (opcional — padrão: False)
DEBUG=False
